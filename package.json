{
  "name": "terlik.js",
  "version": "2.5.0",
  "description": "Ultra-fast, zero-dependency profanity detection engine. Ships with Turkish, English, Spanish & German — extensible to any language. Lazy compilation, deep agglutination support, ReDoS-safe regex patterns",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./tr": {
      "import": {
        "types": "./dist/lang/tr/index.d.mts",
        "default": "./dist/lang/tr/index.mjs"
      },
      "require": {
        "types": "./dist/lang/tr/index.d.ts",
        "default": "./dist/lang/tr/index.js"
      }
    },
    "./en": {
      "import": {
        "types": "./dist/lang/en/index.d.mts",
        "default": "./dist/lang/en/index.mjs"
      },
      "require": {
        "types": "./dist/lang/en/index.d.ts",
        "default": "./dist/lang/en/index.js"
      }
    },
    "./es": {
      "import": {
        "types": "./dist/lang/es/index.d.mts",
        "default": "./dist/lang/es/index.mjs"
      },
      "require": {
        "types": "./dist/lang/es/index.d.ts",
        "default": "./dist/lang/es/index.js"
      }
    },
    "./de": {
      "import": {
        "types": "./dist/lang/de/index.d.mts",
        "default": "./dist/lang/de/index.mjs"
      },
      "require": {
        "types": "./dist/lang/de/index.d.ts",
        "default": "./dist/lang/de/index.js"
      }
    }
  },
  "typesVersions": {
    "*": {
      "tr": ["./dist/lang/tr/index.d.ts"],
      "en": ["./dist/lang/en/index.d.ts"],
      "es": ["./dist/lang/es/index.d.ts"],
      "de": ["./dist/lang/de/index.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "tsx benchmarks/bench.ts",
    "bench:accuracy": "tsx benchmarks/accuracy.ts",
    "bench:compare": "cd benchmarks/comparison && pnpm install && pnpm start",
    "bench:report": "cd benchmarks/comparison && pnpm install && pnpm start",
    "typecheck": "tsc --noEmit",
    "dev:live": "tsx watch tools/server.ts",
    "spdg:generate": "node tools/Synthetic-Profanity-Dataset-Generator/generate_dataset.js --tr --pos 500 --neg 500 --seed 42 && node tools/Synthetic-Profanity-Dataset-Generator/generate_dataset.js --en --pos 500 --neg 500 --seed 42 && node tools/Synthetic-Profanity-Dataset-Generator/generate_dataset.js --es --pos 500 --neg 500 --seed 42 && node tools/Synthetic-Profanity-Dataset-Generator/generate_dataset.js --de --pos 500 --neg 500 --seed 42",
    "test:spdg": "vitest run tests/spdg-automated-test.test.ts",
    "spdg": "pnpm spdg:generate && pnpm test:spdg",
    "prepare": "husky"
  },
  "keywords": [
    "profanity",
    "profanity-filter",
    "profanity-detection",
    "filter",
    "content-filter",
    "content-moderation",
    "moderation",
    "nsfw",
    "censor",
    "badwords",
    "bad-words",
    "swear-words",
    "word-filter",
    "chat-filter",
    "text-moderation",
    "offensive-language",
    "turkish",
    "multi-language",
    "extensible",
    "kufur",
    "küfür",
    "turkce",
    "zero-dependency",
    "typescript",
    "nodejs",
    "isomorphic",
    "regex-engine"
  ],
  "author": "Anthony Burak DURSUN",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/badursun/terlik.js.git"
  },
  "homepage": "https://github.com/badursun/terlik.js#readme",
  "bugs": {
    "url": "https://github.com/badursun/terlik.js/issues"
  },
  "sideEffects": false,
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "tsx": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "engines": {
    "node": ">=18"
  }
}
