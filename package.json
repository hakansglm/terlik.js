{
  "name": "terlik.js",
  "version": "2.2.1",
  "description": "Ultra-fast, zero-dependency multi-language profanity detection engine for Turkish, English, Spanish, and German with lazy compilation, deep agglutination support, and ReDoS-safe regex patterns",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "tsx benchmarks/bench.ts",
    "bench:accuracy": "tsx benchmarks/accuracy.ts",
    "typecheck": "tsc --noEmit",
    "dev:live": "tsx watch live_test_server/server.ts",
    "prepare": "husky"
  },
  "keywords": [
    "profanity",
    "profanity-filter",
    "filter",
    "content-filter",
    "moderation",
    "nsfw",
    "censor",
    "badwords",
    "turkish",
    "english",
    "spanish",
    "german",
    "multi-language",
    "kufur",
    "turkce",
    "zero-dependency",
    "typescript",
    "isomorphic",
    "regex-engine"
  ],
  "author": "Anthony Burak DURSUN",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/badursun/terlik.js.git"
  },
  "homepage": "https://github.com/badursun/terlik.js#readme",
  "bugs": {
    "url": "https://github.com/badursun/terlik.js/issues"
  },
  "sideEffects": false,
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "tsx": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "engines": {
    "node": ">=18"
  }
}
